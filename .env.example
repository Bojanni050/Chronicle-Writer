# Postgres connection string. Matches docker-compose.yml defaults —
# override if you're pointing at a different local/Docker Postgres instance.
DATABASE_URL=postgresql://inkwell:inkwell@localhost:5432/inkwell

# AI providers (all optional; features degrade to stubs when unset)
AI_PROVIDER=stub
EMBEDDING_PROVIDER=stub

