# Read two ways by docker-compose.prod.yml: as compose variable substitution
# (${DOMAIN}, ${CADDY_HTTP_PORT}, ...) and, for the app service, injected via
# `env_file: .env`. Copy this to `.env` (repo root, gitignored) and fill in
# what you need.
#
# DATABASE_URL is NOT set here — docker-compose.prod.yml hardcodes it to
# postgresql://inkwell:inkwell@db:5432/inkwell (container-to-container on the
# compose network, not exposed to the host, so it isn't really a secret here).

# Leave unset to test over plain http(s)://<vm-ip> with a self-signed cert
# (browsers will warn it's untrusted — expected). Set to a real domain name
# whose DNS already points at this VM to get a real, auto-renewed Let's
# Encrypt certificate instead.
# DOMAIN=example.com

# Only needed if 80/443 are already taken on the host.
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443

# AI providers (all optional; features degrade to stubs when unset)
AI_PROVIDER=stub
EMBEDDING_PROVIDER=stub

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OLLAMA_BASE_URL=http://ollama:11434
